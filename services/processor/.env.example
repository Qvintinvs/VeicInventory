# ============================================================================
# Configuração de arquivos de saída do WRFEM
# ============================================================================
# Este arquivo define onde o sistema deve buscar os arquivos binários de saída
# do modelo WRFEM. Eles são lidos e armazenados no banco de dados através da
# função insert_round_wrfem_output().
#
# Formato esperado dos arquivos: binário (ex.: NetCDF, GRIB ou outro formato
# bruto gerado pelo modelo).
#
# ATENÇÃO:
# - Use sempre caminhos absolutos.
# - Verifique permissões de leitura (o processo do Python precisa conseguir
#   abrir os arquivos).
# - Não colocar aspas nem espaços ao redor dos valores.
# ============================================================================

# 📌 Caminho do arquivo de saída referente ao período 00Z–12Z do domínio d01
export WRFEM_OUTPUT_00TO12=/caminho/para/wrfem_00to12z_d01.nc

# 📌 Caminho do arquivo de saída referente ao período 12Z–24Z do domínio d01
export WRFEM_OUTPUT_12TO24=/caminho/para/wrfem_12to24z_d01.nc

# ============================================================================
# Configuração do emiss.exe e diretórios de dados auxiliares
# ============================================================================
# O emiss.exe é compilado em Fortran e deve estar em uma pasta configurada
# aqui. As variáveis abaixo são usadas tanto no Python quanto no bash.
# ============================================================================

# 📌 Diretório de dados: GHG emiss
export GHG_EMIS_DIR=/caminho/projeto/data/ghg_emis

# 📌 Diretório de dados: WRF emiss
export WRF_EMIS_DIR=/caminho/projeto/data/wrf_emis

# 📌 Diretório de dados: EMIS emiss
export EMIS_EMIS_DIR=/caminho/projeto/data/emis_emis

# ============================================================================
# Configuração do banco de dados local (SQLite)
# ============================================================================
# Estas variáveis definem onde o banco SQLite será salvo.
# No ambiente Docker, o caminho é sobrescrito pelo docker-compose.yml.
# ============================================================================

# 📌 Caminho absoluto do banco SQLite para desenvolvimento local
export SQLITE_DB_PATH=/caminho/projeto/instance/wrfem_blobs.db


# ============================================================================
# Configuração do Redis
# ============================================================================
# Se não usar senha: redis://redis:6379/0
# No Docker Compose, esta variável é sobrescrita para apontar para o serviço.
# ============================================================================

# 📌 URL do Redis (formato redis://[:senha@]host:port/db)
export REDIS_URL=redis://redis:6379/0

# ============================================================================
# Configuração do S3
# ============================================================================
# No Docker Compose, o host é sobrescrito para "http://minio:9000".
# ============================================================================

# 📌 URL base do S3
export S3_ENDPOINT_URL=http://minio:9000

# 📌 Credenciais (compatíveis com s3)
export AWS_ACCESS_KEY_ID=minioadmin
export AWS_SECRET_ACCESS_KEY=minioadmin
